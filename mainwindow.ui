  <property name="styleSheet">
   <string notr="true">QWidget#centralwidget {
    background-color: #111015;
}

QGroupBox {
    border: 2px solid #5d3d91;
    border-radius: 12px;
    margin-top: 12px;
    background-color: #1a1623;
    font-weight: 600;
    color: #d8c7ff;
}

QGroupBox::title {
    subcontrol-origin: margin;
    left: 12px;
    padding: 2px 8px;
    background-color: #2b1f3d;
    border: 1px solid #5d3d91;
    border-radius: 6px;
}

QLabel {
    color: #cfbfff;
    font-size: 10pt;
}

QLineEdit, QComboBox {
    border: 1px solid #6a4aa1;
    border-radius: 8px;
    padding: 6px 8px;
    background: #0f0d14;
    color: #f3ebff;
    selection-background-color: #8a63d2;
}

QLineEdit:focus, QComboBox:focus {
    border: 2px solid #9b73e8;
}

QPushButton {
    background-color: #5d3d91;
    color: #f5f0ff;
    border: 1px solid #7b56bd;
    border-radius: 10px;
    padding: 8px 16px;
    font-weight: 600;
    min-height: 20px;
}

QPushButton:hover {
    background-color: #6f49ac;
}

QPushButton:pressed {
    background-color: #4f337c;
}

QTableWidget {
    border: 2px solid #5d3d91;
    border-radius: 10px;
    background: #15121d;
    gridline-color: #34284a;
    alternate-background-color: #1c1727;
    selection-background-color: #7b56bd;
    selection-color: #ffffff;
    color: #f3ebff;
}

QHeaderView::section {
    background-color: #2b1f3d;
    color: #dccdff;
    border: 1px solid #5d3d91;
    padding: 6px;
    font-weight: 600;
}

QWidget#plotWidget {
    border: 2px solid #5d3d91;
    border-radius: 10px;
    background: #15121d;
}</string>
